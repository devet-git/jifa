PORT=8080
DATABASE_URL=postgres://jifa:jifa_secret@localhost:5432/jifa_db?sslmode=disable
JWT_SECRET=change-me-to-a-long-random-string
APP_ENV=development

# SMTP (email notifications)
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=youraccount@gmail.com
# SMTP_PASS=abcd1234abcd1234
# SMTP_FROM=youraccount@gmail.com
# SMTP_FROM_NAME=Jifa

MCP_ENABLED=true

# GitLab integration — AES-256 key used to encrypt the per-project GitLab
# access token at rest. MUST be 64 hex characters (32 bytes).
# Generate with: openssl rand -hex 32
# If not set, the GitLab settings page returns 503 (fail-closed).
# JIFA_INTEGRATION_KEY=replace-with-64-hex-chars